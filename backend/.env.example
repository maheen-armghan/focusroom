# FocusRoom — Environment Variables
# Copy this to .env and fill in your values

# ── App ────────────────────────────────
APP_NAME=FocusRoom
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ── Security ───────────────────────────
JWT_SECRET=change-this-to-a-random-string

# ── Redis (run: docker-compose up redis) ─
REDIS_URL=redis://localhost:6379/0

# ── Gemini API (for chat summaries) ────
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── ML Model ───────────────────────────
# Path relative to where you run uvicorn (project root)
MODEL_PATH=ml_training/checkpoints/best_model.keras
MODEL_IMG_SIZE=32

# ── File Storage (dev = local disk) ────
USE_LOCAL_STORAGE=True
LOCAL_STORAGE_DIR=local_uploads
MAX_FILE_SIZE_MB=25
